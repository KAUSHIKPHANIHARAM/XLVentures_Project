# =============================================================================
# .env.example
# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to version control.
# =============================================================================

# --- Google Gemini Configuration (FREE) ---
# Obtain your free API key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_API_KEY_ENV=GEMINI_API_KEY
EMBEDDING_API_KEY_ENV=GEMINI_API_KEY

# --- Platform Settings ---
PLATFORM_ENV=development
ACTIVE_DOMAIN=customer_management
DB_CONNECTION=./data/platform.db
CHROMA_PERSIST_DIR=./data/vectordb
LOG_LEVEL=INFO
LOG_FILE=
