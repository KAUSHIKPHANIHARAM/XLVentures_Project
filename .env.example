# =============================================================================
# .env.example
# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to version control.
# =============================================================================

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Platform settings (optional — defaults shown)
PLATFORM_ENV=development
ACTIVE_DOMAIN=customer_management

# LLM model override (optional)
LLM_MODEL=gpt-4o

# Embedding model override (optional)
EMBEDDING_MODEL=text-embedding-3-small

# Database (optional)
DB_CONNECTION=./data/platform.db

# Vector store (optional)
CHROMA_PERSIST_DIR=./data/vectordb

# Logging (optional)
LOG_LEVEL=INFO
LOG_FILE=
